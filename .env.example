# ───── Application ─────
APP_NAME="FlySeas Travels"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ───── Logging ─────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ───── Database (MySQL) ─────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=flyseas
DB_USERNAME=root
DB_PASSWORD=

# ───── Session / Cache / Queue ─────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ───── Mail ─────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@flyseastravels.com"
MAIL_FROM_NAME="${APP_NAME}"

# ───── Vite ─────
VITE_APP_NAME="${APP_NAME}"

# ───── FlySeas business config ─────
FLYSEAS_PHONE="+918421617391"
FLYSEAS_WHATSAPP=918421617391
FLYSEAS_EMAIL=hello@flyseastravels.com
FLYSEAS_LOCATION="Nagpur, Maharashtra"

# ───── Admin seed credentials (used only by AdminUserSeeder) ─────
ADMIN_EMAIL=admin@flyseastravels.com
ADMIN_PASSWORD=change-me-in-production
